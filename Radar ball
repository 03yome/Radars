local function killScript()
    for _, con in pairs(scriptCns) do con:Disconnect() end
    for _, obj in ipairs(drawObjects) do pcall(function() obj:Remove() end) end
    _G.RadarKill = nil
end
_G.RadarKill = killScript

local function setRadarScale()
    markerScale = math.clamp(RADAR_SCALE, MARKER_SCALE_MIN, MARKER_SCALE_MAX) * MARKER_SCALE_BASE
    if ( RADAR_LINES ) then
        local lineCount = math.floor(RADAR_RADIUS / (RADAR_SCALE * RADAR_LINE_DISTANCE))
        for idx, line in ipairs(radarLines) do 
            if ( idx > lineCount ) then line.Visible = false else line.Radius = idx * (RADAR_SCALE * RADAR_LINE_DISTANCE) line.Visible = true end
        end
    end
end

local function setRadarPosition(newPosition)
    radarPosition = newPosition
    radarObjects.main.Position = newPosition
    radarObjects.outline.Position = newPosition
    radarObjects.loadOverlay.Position = newPosition
    radarObjects.loadText.Position = newPosition - newV2(0, 15)
    if ( RADAR_LINES ) then
        for _, line in ipairs(radarLines) do line.Position = newPosition end
        radarObjects.horizontalLine.From = newPosition - newV2(RADAR_RADIUS, 0)
        radarObjects.horizontalLine.To = newPosition + newV2(RADAR_RADIUS, 0)
        radarObjects.verticalLine.From = newPosition - newV2(0, RADAR_RADIUS)
        radarObjects.verticalLine.To = newPosition + newV2(0, RADAR_RADIUS)
    end
end

--- Input/Drag/Hover ---
do
    local radarDragging, zoomingIn, zoomingOut = false, false, false
    scriptCns.inputBegan = inputService.InputBegan:Connect(function(io)
        local keyCode = io.KeyCode.Name
        if keyCode == 'End' then killScript()
        elseif keyCode == 'Equals' then zoomingIn = true
            scriptCns.zoomInCn = runService.Heartbeat:Connect(function(dT)
                RADAR_SCALE = math.clamp(RADAR_SCALE + (dT * 0.75), 0.02, 3)
                radarObjects.zoomText.Text = ('Scale: %.2f'):format(RADAR_SCALE)
                radarObjects.zoomText.Position = radarPosition + newV2(0, RADAR_RADIUS + 25)
                setRadarScale()
            end)
        elseif keyCode == 'Minus' then zoomingOut = true
            scriptCns.zoomOutCn = runService.Heartbeat:Connect(function(dT)
                RADAR_SCALE = math.clamp(RADAR_SCALE - (dT * 0.75), 0.02, 3)
                radarObjects.zoomText.Text = ('Scale: %.2f'):format(RADAR_SCALE)
                radarObjects.zoomText.Position = radarPosition + newV2(0, RADAR_RADIUS + 25)
                setRadarScale()
            end)
        elseif io.UserInputType.Name == 'MouseButton1' then
            local mousePos = inputService:GetMouseLocation()
            if (mousePos - radarPosition).Magnitude < RADAR_RADIUS then
                radarDragging = true
                radarObjects.dragHandle.Visible = true
                scriptCns.dragCn = inputService.InputChanged:Connect(function(inputObj)
                    if inputObj.UserInputType.Name == 'MouseMovement' then
                        radarObjects.dragHandle.Position = inputService:GetMouseLocation()
                    end
                end)
            end
        end
    end)

    scriptCns.inputEnded = inputService.InputEnded:Connect(function(io)
        local keyCode = io.KeyCode.Name
        if keyCode == 'Equals' and scriptCns.zoomInCn then scriptCns.zoomInCn:Disconnect()
        elseif keyCode == 'Minus' and scriptCns.zoomOutCn then scriptCns.zoomOutCn:Disconnect()
        elseif io.UserInputType.Name == 'MouseButton1' and radarDragging then
            if scriptCns.dragCn then scriptCns.dragCn:Disconnect() end
            radarDragging = false
            setRadarPosition(radarObjects.dragHandle.Position)
            radarObjects.dragHandle.Visible = false
        end
    end)
end

scriptCns.inputChanged = inputService.InputChanged:Connect(function(input)
    if input.UserInputType.Name == 'MouseMovement' then
        local mousePos = inputService:GetMouseLocation()
        if (mousePos - radarPosition).Magnitude < RADAR_RADIUS then
            local distanceThresh = 15
            local hoverBallName = nil
            for ballObj, thisMark in pairs(ballMarks) do
                local markPos = thisMark.main.Position
                if markPos and (mousePos - markPos).Magnitude < distanceThresh then
                    distanceThresh = (mousePos - markPos).Magnitude
                    hoverBallName = ballObj.Name
                end
            end
            if hoverBallName then
                radarObjects.hoverText.Text = hoverBallName
                radarObjects.hoverText.Position = mousePos + newV2(0, 15)
                radarObjects.hoverText.Visible = true
            else
                radarObjects.hoverText.Visible = false
            end
        else
            radarObjects.hoverText.Visible = false
        end
    end
end)

--- Render Loop ---
scriptCns.radarLoop = runService.Heartbeat:Connect(function()
    if ( not clientRoot ) then return end
    local selfPos = clientRoot.Position
    local camAngle = 0
    
    if ( RADAR_ROTATION ) then
        local cameraLookVec = clientCamera.CFrame.LookVector
        local fixedLookVec = newV3(cameraLookVec.X, 0, cameraLookVec.Z).Unit
        camAngle = math.atan2(fixedLookVec.X, fixedLookVec.Z)
    else
        camAngle = math.rad(180)
    end

    if ( CARDINAL_DISPLAY ) then
        local hOffset = newV2(RADAR_RADIUS + 15, 0)
        local vOffset = newV2(0, RADAR_RADIUS + 15)
        local angleCos, angleSin = mathCos(-camAngle), mathSin(-camAngle)
        radarObjects.directionN.Position = radarPosition + newV2(((-vOffset).X * angleSin) - ((-vOffset).Y * angleCos), ((-vOffset).X * angleCos) + ((-vOffset).Y * angleSin))
        radarObjects.directionS.Position = radarPosition + newV2((vOffset.X * angleSin) - (vOffset.Y * angleCos), (vOffset.X * angleCos) + (vOffset.Y * angleSin))
        radarObjects.directionW.Position = radarPosition + newV2(((-hOffset).X * angleSin) - ((-hOffset).Y * angleCos), ((-hOffset).X * angleCos) + ((-hOffset).Y * angleSin))
        radarObjects.directionE.Position = radarPosition + newV2((hOffset.X * angleSin) - (hOffset.Y * angleCos), (hOffset.X * angleCos) + (hOffset.Y * angleSin))
    end

    radarObjects.localMark.Position = radarPosition

    for ballObj, manager in pairs(ballManagers) do
        local mark = ballMarks[ballObj]
        if not mark or not ballObj:IsDescendantOf(workspace) then continue end
        
        local ballPos = ballObj.Position
        local distance = (selfPos - ballPos).Magnitude
        
        local localX = (ballPos.X - selfPos.X) * RADAR_SCALE
        local localY = (ballPos.Z - selfPos.Z) * RADAR_SCALE
        
        local rotX = localX * mathCos(camAngle) - localY * mathSin(camAngle)
        local rotY = localX * mathSin(camAngle) + localY * mathCos(camAngle)
        
        local radarPos = newV2(rotX, rotY)
        local isOffscreen = radarPos.Magnitude > RADAR_RADIUS
        
        if isOffscreen and not DISPLAY_OFFSCREEN then
            mark.main.Visible = false
            mark.stroke.Visible = false
            continue
        end
        
        if isOffscreen then
            radarPos = radarPos.Unit * RADAR_RADIUS
            mark.main.Transparency = OFFSCREEN_TRANSPARENCY
            mark.stroke.Transparency = OFFSCREEN_TRANSPARENCY
        else
            mark.main.Transparency = 1
            mark.stroke.Transparency = 1
        end
        
        local finalPos = radarPosition + radarPos
        
        if ( DISPLAY_RGB_COLORS ) then
            local hue = (tick() % 5) / 5
            local rgb = Color3.fromHSV(hue, 1, 1)
            mark.main.Color = rgb
            mark.stroke.Color = rgb
        end
        
        local dynamicScale = markerScale
        if ( MARKER_FALLOFF and not isOffscreen ) then
            dynamicScale = math.clamp((MARKER_FALLOFF_AMNT / distance) * markerScale, MARKER_SCALE_MIN, MARKER_SCALE_MAX)
        end
        
        if ( USE_QUADS ) then
            local sVec = newV2(dynamicScale, dynamicScale)
            mark.main.PointA = finalPos + (newV2(0, 5) * sVec)
            mark.main.PointB = finalPos + (newV2(4, -5) * sVec)
            mark.main.PointC = finalPos + (newV2(0, -3) * sVec)
            mark.main.PointD = finalPos + (newV2(-4, -5) * sVec)
            
            mark.stroke.PointA = mark.main.PointA
            mark.stroke.PointB = mark.main.PointB
            mark.stroke.PointC = mark.main.PointC
            mark.stroke.PointD = mark.main.PointD
        else
            mark.main.Radius = dynamicScale * 4
            mark.stroke.Radius = dynamicScale * 4
            mark.main.Position = finalPos
            mark.stroke.Position = finalPos
        end
        
        mark.main.Visible = true
        mark.stroke.Visible = true
    end
end)
