--- Ball Logic ---
local function removeBall(ball)
    local manager = ballManagers[ball]
    if not manager then return end
    if manager.onLeave then manager.onLeave() end
    ballManagers[ball] = nil
end

local function readyBall(ball)
    if not ball:IsA("BasePart") then return end
    
    local manager = { Object = ball, Name = ball.Name }
    ballManagers[ball] = manager
    
    task.spawn(function()
        local markers = {}
        local markMain, markStroke

        if ( USE_QUADS ) then 
            markMain = Drawing.new('Quad')
            markMain.Filled = true
            markMain.Thickness = 2
            markMain.Visible = true
            markMain.ZIndex = 303
            markStroke = Drawing.new('Quad')
            markStroke.Filled = false
            markStroke.Thickness = 2
            markStroke.ZIndex = 302
        else 
            markMain = Drawing.new('Circle')
            markMain.Filled = true
            markMain.NumSides = 20
            markMain.Radius = markerScale * 4
            markMain.Thickness = 2
            markMain.Visible = true
            markMain.ZIndex = 303
            markStroke = Drawing.new('Circle')
            markStroke.Filled = false
            markStroke.NumSides = 20
            markStroke.Radius = markerScale * 4
            markStroke.Thickness = 1
            markStroke.Visible = true
            markStroke.ZIndex = 302
        end

        table.insert(drawObjects, markMain)
        table.insert(drawObjects, markStroke)

        markMain.Color = RADAR_THEME.Ball_Marker
        markStroke.Color = RADAR_THEME.Ball_Marker

        manager.onLeave = function()
            local idx1 = table.find(drawObjects, markMain)
            if idx1 then table.remove(drawObjects, idx1) end
            local idx2 = table.find(drawObjects, markStroke)
            if idx2 then table.remove(drawObjects, idx2) end
            
            task.spawn(function()
                tweenExp(markMain, 'Transparency', 0, 0.3)
                tweenExp(markStroke, 'Transparency', 0, 0.3)
                task.wait(0.4)
                markMain:Remove()
                markStroke:Remove()
            end)
            ballMarks[ball] = nil
        end

        markers.main = markMain
        markers.stroke = markStroke
        ballMarks[ball] = markers
    end)
end

for _, ball in ipairs(BallsFolder:GetChildren()) do readyBall(ball) end
scriptCns.ballAdd = BallsFolder.ChildAdded:Connect(readyBall)
scriptCns.ballRemove = BallsFolder.ChildRemoved:Connect(removeBall)

